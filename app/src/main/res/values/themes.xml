<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.AgeVerify" parent="Theme.MaterialComponents.NoActionBar">
        <item name="android:windowBackground">@color/bg_deep_space</item>
        <item name="android:statusBarColor">@color/bg_deep_space</item>
        <item name="android:navigationBarColor">@color/bg_deep_space</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="colorPrimary">@color/primary_electric</item>
        <item name="colorPrimaryDark">@color/bg_deep_space</item>
        <item name="colorAccent">@color/accent_mint</item>
        <item name="android:textColorPrimary">@color/text_ghost_white</item>
        <item name="android:textColorSecondary">@color/text_steel_grey</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <!-- Headline Style -->
    <style name="TextAppearance.AgeVerify.Headline" parent="TextAppearance.MaterialComponents.Headline4">
        <item name="android:fontFamily">sans-serif-condensed-light</item>
        <item name="android:textColor">@color/text_ghost_white</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <!-- Mono Style for Stats/Data -->
    <style name="TextAppearance.AgeVerify.Mono" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/primary_electric</item>
    </style>

    <!-- Camera activity — true fullscreen, no status bar -->
    <style name="Theme.AgeVerify.Camera" parent="Theme.AgeVerify">
        <item name="android:windowFullscreen">false</item>
        <item name="android:statusBarColor">@color/transparent</item>
        <item name="android:windowTranslucentStatus">true</item>
    </style>
</resources>
