<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:layout_marginBottom="12dp">

    <!-- Number badge -->
    <TextView
        android:id="@+id/tvStepNumber"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:text="1"
        android:textColor="@color/electric"
        android:textSize="12sp"
        android:textStyle="bold"
        android:gravity="center"
        android:background="@drawable/bg_step_badge"
        android:layout_marginEnd="14dp" />

    <!-- Label -->
    <TextView
        android:id="@+id/tvStepLabel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="Step label"
        android:textColor="@color/text_primary"
        android:textSize="14sp" />

    <!-- Check — shown when step is done -->
    <TextView
        android:id="@+id/tvStepCheck"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✓"
        android:textColor="@color/success"
        android:textSize="16sp"
        android:visibility="invisible" />

</LinearLayout>
