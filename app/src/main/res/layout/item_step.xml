<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_step_row"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="12dp"
    android:paddingVertical="10dp">

    <TextView
        android:id="@+id/tvStepNumber"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_marginEnd="12dp"
        android:background="@drawable/bg_step_badge"
        android:fontFamily="monospace"
        android:gravity="center"
        android:text="1"
        android:textColor="@color/primary_electric"
        android:textSize="11sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvStepLabel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:fontFamily="sans-serif-medium"
        android:text="Step label"
        android:textColor="@color/text_ghost_white"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tvStepCheck"
        android:layout_width="26dp"
        android:layout_height="26dp"
        android:background="@drawable/bg_success_dot"
        android:fontFamily="monospace"
        android:gravity="center"
        android:text="OK"
        android:textColor="@color/success_glow"
        android:textSize="9sp"
        android:visibility="invisible" />

</LinearLayout>
