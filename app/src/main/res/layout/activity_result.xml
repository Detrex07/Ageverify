<?xml version="1.0" encoding="utf-8"?>
<!--
    Result screen.
    Three visual states controlled programmatically:
    A) SUCCESS — green credential card, token details
    B) AGE FAIL — red card, access denied message, no retry
    C) ERROR — neutral card, retry button
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/dark_bg"
    android:paddingHorizontal="24dp"
    android:gravity="center_vertical">

    <!-- Large status icon -->
    <TextView
        android:id="@+id/tvStatusIcon"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:text="✓"
        android:textColor="@color/success"
        android:textSize="40sp"
        android:gravity="center"
        android:background="@drawable/bg_card_success"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="28dp" />

    <!-- Title -->
    <TextView
        android:id="@+id/tvResultTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/result_success_title"
        android:textColor="@color/text_primary"
        android:textSize="30sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="8dp" />

    <!-- Subtitle -->
    <TextView
        android:id="@+id/tvResultSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/result_success_subtitle"
        android:textColor="@color/text_secondary"
        android:textSize="15sp"
        android:gravity="center"
        android:lineSpacingMultiplier="1.4"
        android:layout_marginBottom="36dp" />

    <!-- Credential detail card — visible on success -->
    <LinearLayout
        android:id="@+id/cardCredential"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_card"
        android:padding="20dp"
        android:visibility="gone"
        android:layout_marginBottom="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CREDENTIAL DETAILS"
            android:textColor="@color/text_muted"
            android:textSize="10sp"
            android:letterSpacing="0.12"
            android:textAllCaps="true"
            android:layout_marginBottom="16dp" />

        <!-- Age row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/result_age_label"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />
            <TextView
                android:id="@+id/tvDetailAge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="18+"
                android:textColor="@color/success"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Jurisdiction row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/result_jurisdiction_label"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />
            <TextView
                android:id="@+id/tvDetailJurisdiction"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="@color/text_primary"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Expires row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/result_expires_label"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />
            <TextView
                android:id="@+id/tvDetailExpires"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="@color/text_primary"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/border"
            android:layout_marginBottom="12dp" />

        <!-- JWT token preview -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SIGNED TOKEN"
            android:textColor="@color/text_muted"
            android:textSize="10sp"
            android:letterSpacing="0.12"
            android:textAllCaps="true"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/tvTokenPreview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="eyJ..."
            android:textColor="@color/electric"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:maxLines="2"
            android:ellipsize="end" />
    </LinearLayout>

    <!-- Source badge — shows STANDALONE_APP or IN_APP -->
    <TextView
        android:id="@+id/tvSourceBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Verified via this app"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:paddingHorizontal="12dp"
        android:paddingVertical="5dp"
        android:background="@drawable/bg_card"
        android:layout_gravity="center_horizontal"
        android:visibility="gone"
        android:layout_marginBottom="32dp" />

    <!-- Done / Retry button -->
    <TextView
        android:id="@+id/btnPrimary"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="@string/result_done"
        android:textColor="@color/dark_bg"
        android:textSize="16sp"
        android:textStyle="bold"
        android:gravity="center"
        android:background="@drawable/bg_btn_primary"
        android:layout_marginBottom="16dp" />

    <!-- Privacy note -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/result_privacy_note"
        android:textColor="@color/text_muted"
        android:textSize="12sp"
        android:gravity="center"
        android:lineSpacingMultiplier="1.5"
        android:layout_marginTop="8dp" />

</LinearLayout>
