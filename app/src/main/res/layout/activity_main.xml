<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_gradient"
    android:fillViewport="true"
    android:scrollbars="none">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="22dp"
        android:paddingTop="52dp"
        android:paddingBottom="36dp">

        <LinearLayout
            android:id="@+id/layoutLogo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="@drawable/bg_logo_mark"
                android:fontFamily="sans-serif-black"
                android:gravity="center"
                android:text="AV"
                android:textColor="@color/bg_deep_space"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:fontFamily="sans-serif-medium"
                android:text="AgeVerify"
                android:textColor="@color/text_ghost_white"
                android:textSize="18sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_dark_pill"
                android:fontFamily="monospace"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="v0.1.0"
                android:textColor="@color/text_muted"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutNotVerified"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:orientation="vertical"
            app:layout_constraintTop_toBottomOf="@id/layoutLogo">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_electric_pill"
                android:fontFamily="monospace"
                android:letterSpacing="0.12"
                android:paddingHorizontal="12dp"
                android:paddingVertical="5dp"
                android:text="ON-DEVICE VERIFICATION"
                android:textAllCaps="true"
                android:textColor="@color/primary_electric"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/tvTagline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:fontFamily="sans-serif-black"
                android:includeFontPadding="false"
                android:lineSpacingExtra="-4dp"
                android:text="Age\nverified.\nPrivate."
                android:textColor="@color/text_ghost_white"
                android:textSize="42sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:lineSpacingMultiplier="1.45"
                android:text="Your ID and face stay on this phone. OCR, liveness, face match, and credential signing run locally."
                android:textColor="@color/text_steel_grey"
                android:textSize="15sp" />

            <LinearLayout
                android:id="@+id/layoutStats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="26dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="96dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_stat_tile"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:fontFamily="monospace"
                        android:text="BYTES SENT"
                        android:textColor="@color/text_muted"
                        android:textSize="10sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-black"
                        android:text="0"
                        android:textColor="@color/primary_electric"
                        android:textSize="32sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="96dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_stat_tile"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:fontFamily="monospace"
                        android:text="STATUS"
                        android:textColor="@color/text_muted"
                        android:textSize="10sp" />

                    <TextView
                        android:id="@+id/tvStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-black"
                        android:text="READY"
                        android:textColor="@color/accent_mint"
                        android:textSize="24sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutFlow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:background="@drawable/bg_glass_card"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvFlowTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.1"
                    android:text="THREE STEPS TO VERIFY"
                    android:textColor="@color/text_muted"
                    android:textSize="10sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="vertical">

                    <include android:id="@+id/step1" layout="@layout/item_step" />
                    <include android:id="@+id/step2" layout="@layout/item_step" />
                    <include android:id="@+id/step3" layout="@layout/item_step" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/btnStart"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="22dp"
                android:background="@drawable/bg_btn_primary_cyber"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:text="Start Verification"
                android:textColor="@color/bg_deep_space"
                android:textSize="16sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:lineSpacingMultiplier="1.3"
                android:text="No data transmitted. No biometric storage. Credential only."
                android:textColor="@color/text_muted"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutVerified"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="34dp"
            android:background="@drawable/bg_credential_verified"
            android:orientation="vertical"
            android:padding="20dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/layoutLogo">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_electric_pill"
                android:fontFamily="monospace"
                android:paddingHorizontal="12dp"
                android:paddingVertical="5dp"
                android:text="VERIFIED CREDENTIAL"
                android:textColor="@color/success_glow"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/tvAgeConfirmed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:fontFamily="sans-serif-black"
                android:text="21+"
                android:textColor="@color/text_ghost_white"
                android:textSize="52sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvJurisdiction"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="California, USA"
                android:textColor="@color/text_steel_grey"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tvExpiresAt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="monospace"
                android:text="Expires 24 May 2025"
                android:textColor="@color/text_muted"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/btnReverify"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_btn_secondary"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:text="Reverify"
                android:textColor="@color/text_ghost_white"
                android:textSize="14sp" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
