<?xml version="1.0" encoding="utf-8"?>
<!--
    Main / Welcome screen.
    Two states:
    A) Not yet verified → show steps + Start button
    B) Already verified → show credential card + Re-verify option
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_bg"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="64dp"
        android:paddingBottom="40dp">

        <!-- Wordmark / Logo row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="48dp">

            <!-- Logo badge -->
            <FrameLayout
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@color/electric"
                android:layout_marginEnd="12dp">
                <!-- A in place of icon until vector is ready -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="A"
                    android:textColor="@color/dark_bg"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AgeVerify"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold"
                android:letterSpacing="0.02" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <!-- Version tag -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="v0.1"
                android:textColor="@color/text_muted"
                android:textSize="11sp"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:background="@drawable/bg_card" />
        </LinearLayout>

        <!-- Hero text -->
        <TextView
            android:id="@+id/tvTagline"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/main_tagline"
            android:textColor="@color/text_primary"
            android:textSize="36sp"
            android:textStyle="bold"
            android:lineSpacingMultiplier="1.1"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/main_subtitle"
            android:textColor="@color/text_secondary"
            android:textSize="15sp"
            android:lineSpacingMultiplier="1.4"
            android:layout_marginBottom="40dp" />

        <!-- ── ALREADY VERIFIED STATE ── (hidden by default) -->
        <LinearLayout
            android:id="@+id/layoutVerified"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginBottom="24dp">

            <!-- Credential card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_success"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <!-- Header row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Age Credential"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <!-- Verified badge -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✓  VERIFIED"
                        android:textColor="@color/success"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:background="@drawable/bg_card" />
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/border"
                    android:layout_marginBottom="16dp" />

                <!-- Credential details grid -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Age confirmed"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"
                            android:layout_marginBottom="2dp" />
                        <TextView
                            android:id="@+id/tvAgeConfirmed"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="18+"
                            android:textColor="@color/text_primary"
                            android:textSize="22sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Jurisdiction"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"
                            android:layout_marginBottom="2dp" />
                        <TextView
                            android:id="@+id/tvJurisdiction"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="@color/text_primary"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Valid until"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:layout_marginBottom="2dp" />
                    <TextView
                        android:id="@+id/tvExpiresAt"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Re-verify button -->
            <TextView
                android:id="@+id/btnReverify"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/main_btn_reverify"
                android:textColor="@color/text_secondary"
                android:textSize="15sp"
                android:gravity="center"
                android:background="@drawable/bg_btn_secondary" />
        </LinearLayout>

        <!-- ── NOT VERIFIED STATE ── -->
        <LinearLayout
            android:id="@+id/layoutNotVerified"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="visible">

            <!-- Steps card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="20dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/main_steps_title"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:letterSpacing="0.1"
                    android:textAllCaps="true"
                    android:layout_marginBottom="16dp" />

                <!-- Step 1 -->
                <include layout="@layout/item_step"
                    android:id="@+id/step1" />

                <!-- Step 2 -->
                <include layout="@layout/item_step"
                    android:id="@+id/step2" />

                <!-- Step 3 -->
                <include layout="@layout/item_step"
                    android:id="@+id/step3" />
            </LinearLayout>

            <!-- Start button -->
            <TextView
                android:id="@+id/btnStart"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="@string/main_btn_start"
                android:textColor="@color/dark_bg"
                android:textSize="16sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/bg_btn_primary" />
        </LinearLayout>

        <!-- Privacy note — always visible -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/main_privacy_note"
            android:textColor="@color/text_muted"
            android:textSize="12sp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.5"
            android:layout_marginTop="32dp" />

    </LinearLayout>
</ScrollView>
